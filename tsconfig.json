{
  "compilerOptions": {
    "declaration": true,
    "outDir": "./dist",
    "target": "es2020",
    "module": "esnext",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}